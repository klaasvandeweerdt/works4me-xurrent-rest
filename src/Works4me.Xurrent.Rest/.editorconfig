[*.cs]

############################################
# Target framework compatibility
############################################

# Span-based APIs are not uniformly available across all target frameworks
dotnet_diagnostic.CA1845.severity = none

# Throw helper APIs are not available on all target frameworks
dotnet_diagnostic.CA1510.severity = none
dotnet_diagnostic.CA1513.severity = none


############################################
# SDK API design decisions
############################################

# Allow nested public operation groups for fluent SDK APIs
dotnet_diagnostic.CA1034.severity = none

# Collection properties are settable to support serialization and data binding
dotnet_diagnostic.CA2227.severity = none

# Namespaces are intentionally flattened for a cleaner public API surface
dotnet_diagnostic.IDE0130.severity = none


############################################
# Style preferences (intentional)
############################################

# Prefer traditional using statements for clarity
dotnet_diagnostic.IDE0063.severity = none

# Range operator is not available on all target frameworks
dotnet_diagnostic.IDE0057.severity = none

# CA1700: Do not name enum values 'Reserved'
dotnet_diagnostic.CA1700.severity = none
